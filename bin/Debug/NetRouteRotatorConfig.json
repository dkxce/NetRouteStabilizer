{
  /*JSON VPNGate Servers File from /collect*/
  "VPNServersFile": "vpngate_full_list.json"
  /*VPNGate text to find servers in VPNCmd AccountList*/,
  "VPNServersFind": "opengw.net"
  /*VPNGate Atapter name (VPN/VPN2/VPN3 ...)*/,
  "VPNAdapterName": "VPN"
  /*VPNGate Account Format for VPNCmd AccountCreate*/,
  "VPNAccountFormat": "%CountryShort% %HostName%.opengw.net"
  /*VPNGate Hostname(Server) Format for VPNCmd AccountCreate*/,
  "VPNServerFormat": "%IP%/tcp:%TcpPort%"
  /*Check ping VPNGate server before add new*/,
  "VPNServerPing": true
  /*Hide VPNGate account statuses on connect/retries*/,
  "VPNHideStatus": true
  /*Skip VPNGate server if info is to old*/,
  "VPNSkipOldDays": 0
  /*Max attempts to connect to existings VPNGate accounts*/,
  "MaxExistingAttempts": 5
  /*Max attempts to connect to new VPNGate accounts*/,
  "MaxNewServerAttempts": 100
  /*Attempts each new server XXX step to connect to existings VPNGate accounts*/,
  "NewServerAttemptExistingStep": 0
  /*Connection delay timeout*/,
  "ConnectDelay": 15
  /*Disconnection delay timeout*/,
  "DisconnectDelay": 3
  /*Delete delay timeout*/,
  "DetectDelay": 5
  /*Countries to select VPNGate Servers in ...*/,
  "Countries": [
    "JP",
    "KR",
    "TW",
    "DE",
    "FR",
    "FI"
  ]
  /*StdOut Log Line Format DateTime*/,
  "LogDateTimeFormat": "dd HH:mm:ss"
}